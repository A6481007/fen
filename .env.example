# Backend & infrastructure defaults
NODE_ENV=development
PORT=3000
DB_PASSWORD=change-me
DATABASE_URL=postgresql://ncsadmin:change-me@localhost:5432/ncsdb
CACHE_REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-secure-random-string
SITE_URL=http://localhost:3000
REVALIDATE_SECRET=change-me
REVALIDATE_ENDPOINT=http://localhost:3000/api/admin/revalidate
FEATURE_EVENTS_AUTO_PAST=0
I18N_ENABLE_THAI_SLUG=0
ENABLE_NEW_QUOTATIONS=false

# Frontend defaults
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_STOREFRONT_API_URL=http://localhost:3000/api
NEXT_PUBLIC_STOREFRONT_MOCK=1
NEXT_PUBLIC_STOREFRONT_MOCK_BASE_URL=/api
STOREFRONT_MOCK=1
NEXT_PUBLIC_ENABLE_NEW_QUOTATIONS=false
NEXT_PUBLIC_ENABLE_ADMIN_STUDIO=false
WEB_WHATS_NEW_DYNAMIC=0
STATIC_FALLBACK_PATH=frontend/src/data/whats-new-fallback.json
CONTENT_REVALIDATE_SECONDS=300
# Sanity (required for content to render)
NEXT_PUBLIC_SANITY_PROJECT_ID=td5crv6z
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-11-09
# Optional: set your public site base for Studio previews
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Sanity tokens (server-side)
# Create a read token in Sanity Manage and keep it secret
# SANITY_API_READ_TOKEN=your-read-token
# SANITY_API_TOKEN=your-write-token-if-needed
# Server-to-server (Next.js API routes -> backend)
BACKEND_API_URL=http://localhost:3000/api
# Provide a service token if the backend requires Authorization
# BACKEND_SERVICE_TOKEN=dev-service-token
# BACKEND_SERVICE_TOKEN_HEADER=Authorization
# BACKEND_SERVICE_TOKEN_SCHEME=Bearer  # set to "none" to send the token as-is

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000
# Optional messaging service SID for high-volume sends
TWILIO_MESSAGING_SERVICE_SID=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
